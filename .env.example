### rename this file to .env and edit the settings to your liking

# Timezone
TIMEZONE='Europe/Amsterdam'

# Module/Feature toggles
# You can select one or more modules to run but make sure that `mqtt_client` is always enabled and is always the
# module defined. This is because the `mqtt_client` module is the one that is responsible for the MQTT connection
# and is a blocking function which will not return while the other modules run in their own threads.
ACTIVE_MODULES='[{"sync": {"ev_charge_controller": false, "energy_broker": false }, "async": {"mqtt_client": true, "tibber_api": false }}]'

# Enable / disable appliance run scheduling at lowest prices (requires a homeconnect2mqtt bridge in local network)
HOME_CONNECT_APPLIANCE_SCHEDULING=False

# Enable / disable dynamic buy and sell decisions (Legacy system - replaced by the AI-powered ESS optimizer)
ESS_NET_METERING_ENABLED=False

# Percentage of battery capacity to retain for own use (ie. stop energy sale at 65% battery state of charge)
ESS_NET_METERING_BATT_MIN_SOC=0

VICTRON_OPTIMIZED_CHARGING=0
TIBBER_UPDATES_ENABLED=1

# the max amount you want to pay in cents per kWh from Tibber (energy supplier) when charging the ESS
MAX_TIBBER_BUY_PRICE=0.40

# Nightly scheduled charging guardrails
# When enabled, the 21:30 nightly scheduler will skip scheduling new charge slots
# if the battery SoC is already within the configured high range.
NIGHT_CHARGE_SKIP_ENABLED=1
NIGHT_CHARGE_SKIP_MIN_SOC=70
NIGHT_CHARGE_SKIP_MAX_SOC=100

# !!! Warning !!!
# Unless mitigated in some other way, if the grid is lost when using this mode, the loads will also
# lose power until grid power is restored or manual intervention is done (switch back to inverter mode on).
# Use this carefully.
#
# If energy prices are equal or lower to this, switch to grid consumption (victron inverter pass-through mode)
SWITCH_TO_GRID_PRICE_THRESHOLD=0.00

### ev_charge_controller ESS options
# LOAD_RESERVATION defines the amount of solar energy produced in Watts that you want to reserve for charging your ESS
# and running house (and other) loads. When the MINIMUM_ESS_SOC percentage is reached, this amount will be reduced with
# a division of the LOAD_RESERVATION by the LOAD_REDUCTION_FACTOR to begin favoring the charge of your electric vehicle.
LOAD_RESERVATION=200
LOAD_REDUCTION_FACTOR=1

# battery will charge at this voltage when under MIMIMUM_ESS_SOC
BATTERY_ABSORPTION_VOLTAGE=57.0
# battery charge voltage will be reduced to this voltage WHEN MIMIMUM_ESS_SOC is reached
BATTERY_FLOAT_VOLTAGE=57.0
MINIMUM_ESS_SOC=90
# batter max voltage will drop to this when MAXIMUM_ESS_SOC is reached
BATTERY_FULL_VOLTAGE=56.20
MAXIMUM_ESS_SOC=100
BATTERY_SUSTAIN_PERCENT=0

### ABB B2x  kWh Meter integration
# if you have integrated an ABB B23/B24 RS-485 meter into your venusOS system you can toggle this option on
# and configure the topic it will read/write to in conf.py.  This will allow for bypassing the load reservation
# functionality and result in more precise and accurate surplus power calculations
ABB_METER_INTEGRATION=1

#################################################################################################
### ESS Optimizer settings can be manages from the UI or in the following section               #
########### NEW ESS ALGORITHM SETTINGS ##########################################################
AI_POWERED_ESS_ALGORITHM=True
BATTERY_CAPACITY_KWH=42.0
AC_DC_CHARGE_EFFICIENCY=0.96
AC_DC_DISCHARGE_EFFICIENCY=0.96

# Minimum battery SoC reserve (%) the optimizer always keeps, by season.
# Winter keeps a larger reserve for grid-outage resilience; summer can run lower.
MIN_SOC_RESERVE_WINTER=20.0
MIN_SOC_RESERVE_SUMMER=5.0

# DP state-of-charge discretization step (percentage points). Smaller = finer
# control but more compute (number of states ~= 100/step; keep it a divisor of
# 100 such as 10, 5, 4, 2). 5.0 is a good balance for Pi-class hardware.
OPTIMIZER_SOC_STEP_PCT=1.0

# Fallback DAILY house load (kWh per 24h) the optimizer uses for its per-slot load
# forecast when the VRM consumption forecast is unavailable.
DAILY_HOME_ENERGY_CONSUMPTION=18.0

# --- PV forecast shape + intraday self-correction ---------------------------
# The per-slot PV forecast = a daily magnitude distributed by a learned daylight
# SHAPE. The magnitude normally comes from VRM, which anchors to a fixed daily
# total — so on a better-than-forecast day "remaining" collapses toward 0 while
# the panels are still producing. These let the magnitude self-correct from how
# much we've actually produced so far today.
#   ESS_PV_SHAPE_DAYS          : trailing days of history for the daylight shape.
#   ESS_PV_INTRADAY_CORRECTION : damping 0..1 for the upward correction (0 = off,
#                                pure VRM; 0.6 = move 60% of the way to the
#                                realised-rate projection).
#   ESS_PV_INTRADAY_MAX_RATIO  : cap on projected day total vs VRM (anti-runaway).
#   ESS_PV_INTRADAY_MIN_ELAPSED: min fraction of the day's solar (by shape) that
#                                must have elapsed before extrapolating (avoids
#                                wild dawn projections off a tiny denominator).
ESS_PV_SHAPE_DAYS=3
ESS_PV_INTRADAY_CORRECTION=0.6
ESS_PV_INTRADAY_MAX_RATIO=1.6
ESS_PV_INTRADAY_MIN_ELAPSED=0.10

# Grid/battery power limits (kW) used by the optimizer's feasibility checks.
# Set to the system's true continuous capability; the Victron ESS + BMS + grid-code
# feed-in limit remain the real hardware guardrails, so the optimizer should not be
# the binding cap. Verify against your inverter's continuous AC rating and grid
# feed-in allowance before raising further.
ESS_MAX_GRID_IMPORT_KW=13.0
# Export ceiling set from observed peak grid export over the last 5 days
# (max seen ~12.2 kW on 2026-06-15, rounded up). Keeps the plan's expected
# discharge revenue / SoC trajectory realistic rather than assuming 16 kW.
ESS_MAX_GRID_EXPORT_KW=13.0
# Optional: cap battery charge/discharge power separately (defaults to the grid limits).
ESS_MAX_CHARGE_KW=13.0
# Discharge ceiling from observed peak battery discharge over the last 5 days
# (max seen ~14.7 kW on 2026-06-14, rounded up).
ESS_MAX_DISCHARGE_KW=15.0
# Negative AC power setpoint commanded for a forced SELL (grid export). The Victron
# ESS / grid-code feed-in limit caps the actual export safely. Aligned to the observed
# ~12.2 kW peak grid export (rounded up to 13 kW) so the forced-sell command matches
# what the system can actually deliver.
ESS_EXPORT_AC_SETPOINT=-13000.0

# Model charging as full-power-to-target for REPORTING/settlement. The system charges
# at full power until the target SoC, then holds (commanded via setpoints under DVCC —
# ESS Optimized without BatteryLife), whereas the DP tie-breaks to a gentle trickle on
# flat-price windows — which made
# BUY settlement predictions read far too low. When on (1), the reported per-slot
# trajectory/economics are re-timed to match the real charge behaviour. Control
# (the Victron charge windows + the BUY setpoint of 0) is unchanged either way.
# Set 0 to report the raw DP trajectory. 1 = on (default).
ESS_MODEL_CHARGE_RATE=1

# Export economics. The optimizer values grid imports at the Tibber buy price
# (incl. fees/taxes) and exports at: buy_price * ESS_EXPORT_PRICE_FACTOR - ESS_EXPORT_FEE.
# Defaults (1.0 / 0.0) treat buy and sell prices symmetrically. Lower the factor
# and/or raise the fee to reflect that Tibber pays only the spot component for exports.
ESS_EXPORT_PRICE_FACTOR=1.0
ESS_EXPORT_FEE=0.0

# Value assigned to energy left in the battery at the end of the planning horizon,
# expressed as a multiple of the horizon's mean buy price. 1.0 keeps the optimizer
# from dumping the battery to the grid at the end of the window so charge can be
# carried into the next (more expensive) day. 0.0 disables terminal valuation.
ESS_TERMINAL_VALUE_FACTOR=1.0

# Expected peak buy price (currency/kWh). When > 0, end-of-horizon stored energy
# is valued at the higher of the horizon mean and this expected peak, so the
# optimizer holds charge for the typical morning/evening peaks (maximising monthly
# revenue) instead of selling into a low intra-day "high". 0 disables.
ESS_EXPECTED_PEAK_PRICE=0.0

# Hard floor (currency/kWh) below which the battery is NEVER actively discharged
# to the grid. PV-surplus feed-in is still allowed. Prevents selling stored energy
# cheaply when a real peak is likely later. 0 disables the floor.
ESS_MIN_SELL_PRICE=0.05

# Battery wear cost charged per kWh discharged from the battery (currency/kWh).
# Stops the optimizer from cycling the battery for marginal arbitrage that
# round-trip losses would eat anyway. Set to your estimated LFP cycle cost
# (e.g. ~0.03-0.06). 0 disables (no wear penalty).
ESS_BATTERY_CYCLE_COST=0.03

# (#1) Arbitrage hurdle (currency/kWh discharged), ON TOP of the wear cost above.
# A required profit cushion so thin-spread cycles (which barely clear round-trip
# losses and are most exposed to forecast error) are pruned, while fat-spread
# cycles (e.g. cheap midday charge -> evening peak sell) still clear. Start small
# (e.g. 0.02-0.04) and tune. 0 disables.
# Set to 0.03 as a forecast-error cushion: the big midday->evening spreads (~0.16)
# clear it easily, but marginal same-price cycles (most exposed to load/EV/charge-
# rate forecast error) are pruned. Revert to 0.00 if it ever suppresses a wanted sell.
ESS_ARBITRAGE_MARGIN=0.03

# (#3) Grid-charge price ceilings — only charge the battery FROM THE GRID when
# energy is genuinely cheap, so expensive grid energy isn't stored for a thin
# resale margin. PV charging is never gated, and topping up to the seasonal
# reserve is always allowed. Both limits apply together when enabled:
#   ESS_MAX_GRID_CHARGE_PRICE : absolute ceiling (currency/kWh). E.g. 0.18 blocks
#                               grid-charging whenever the buy price exceeds 0.18.
#                               0 disables.
#   ESS_GRID_CHARGE_CHEAP_PCT : relative ceiling — only grid-charge when the buy
#                               price is in the cheapest N% of the planning
#                               horizon (adapts per-day, no retuning). E.g. 35.
#                               0 or >=100 disables.
ESS_MAX_GRID_CHARGE_PRICE=0.23
ESS_GRID_CHARGE_CHEAP_PCT=0.00

# Cost-basis sell floor: the optimizer tracks the weighted price actually PAID for
# the energy currently in the battery (grid charging raises it, PV charging dilutes
# it toward 0) and will not actively discharge to the grid below that price plus
# discharge losses — so it can never sell stored energy for less than it cost. The
# basis persists across re-plans/restarts in the file below. No knob to enable; it
# is automatic and self-disables on an empty / PV-filled battery.
ESS_COST_BASIS_PATH=data/ess_cost_basis.json

# SELL hysteresis (anti-flap). The optimizer re-plans from scratch every cycle, so
# on a flat price curve it can flip SELL<->HOLD on sub-cent noise, micro-cycling a
# near-empty battery. These only ever SUPPRESS *entering* a sell (never force a
# discharge): once selling stops, don't re-enter for ESS_SELL_MIN_DWELL_MIN minutes
# unless the price has risen by at least ESS_SELL_HYSTERESIS_EUR since. Exiting a
# sell is always allowed immediately. Set dwell to 0 to disable.
ESS_SELL_MIN_DWELL_MIN=20
ESS_SELL_HYSTERESIS_EUR=0.03

# Planning resolution in minutes. With hourly Tibber prices the engine sub-divides
# each hour into slots of this size (15 = future-ready for quarter-hourly prices;
# prices are flat within the hour until Tibber publishes 15-min data). When the
# price feed is already finer than this, the native resolution is used.
OPTIMIZER_SLOT_MINUTES=15

# Tibber price resolution requested from the API. QUARTER_HOURLY pulls true
# 15-minute prices (how Tibber bills as of Oct 2025) via a direct GraphQL query;
# HOURLY requests hourly prices. Falls back to hourly automatically if the
# market/home does not provide quarter-hourly data.
TIBBER_PRICE_RESOLUTION=QUARTER_HOURLY

# Optional: house-load shape used to forecast self-consumption per slot. 24
# comma-separated relative weights (00:00..23:00); leave unset to use the
# built-in residential profile (low overnight, morning + evening peaks). The
# daily total is taken from the VRM consumption forecast (or measured-so-far,
# or DAILY_HOME_ENERGY_CONSUMPTION) and distributed using this shape.
# LOAD_PROFILE_HOURLY=0.6,0.5,0.5,0.5,0.5,0.7,1.1,1.4,1.3,1.0,0.9,0.9,1.0,1.0,0.9,0.9,1.1,1.6,1.8,1.8,1.6,1.4,1.0,0.7

# When enabled, the optimizer toggles the Victron "Limit system feed-in" setting
# (MaxFeedInPower) to 0W while the current price is negative, and auto-reverts to
# unlimited (-1) once the price is non-negative again.
NEGATIVE_PRICE_FEED_IN_LIMIT_ENABLED=True

### Historical data logging (per-cycle NDJSON for later analytics)
HISTORY_DIR=data/history
#################################################################################################

### Frontend dashboard (frontend/) ##############################################################
# When True, the main service launches the read-only dashboard in-process as a
# daemon thread (guarded — a frontend failure can never crash the controller).
# Leave False to run it standalone (python -m frontend) or as a container sidecar.
FRONTEND_ENABLED=True
AI_PLAN_EXPORT_PATH=/dev/shm/cerbo_ai_plan.json
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=8080
# Log every dashboard HTTP request (werkzeug). Off keeps the service log clean.
FRONTEND_DEBUG=False
# Domoticz device IDXs read for the dashboard (EV charging power W, gas usage m³).
DOMOTICZ_EV_IDX=627
DOMOTICZ_GAS_IDX=291

# --- AI Advisor (read-only dashboard review tab) ---------------------------
# Credentials live in .secrets (CLAUDE_CODE_OAUTH_TOKEN preferred, ANTHROPIC_API_KEY
# fallback). Only the allow-listed tunables (config_schema.py) + performance history
# are ever sent to the model — never secrets. The advisor cannot change anything.
#   ADVISOR_AUTH        : auto | cli | api. 'cli' uses the Claude Code CLI on this
#                         host — the host's existing `claude` login (no token needed)
#                         or CLAUDE_CODE_OAUTH_TOKEN if set. 'auto' uses a token/API
#                         key if present. Set 'cli' when `claude` is already logged in.
#   ADVISOR_MODEL       : optional override. CLI accepts sonnet|opus|haiku; the API
#                         needs a full model id (e.g. claude-sonnet-4-6). Blank = sonnet.
#   ADVISOR_HISTORY_DAYS: trailing days of history to analyse (detail for the last 2).
#   CLAUDE_CLI_PATH     : path to the Claude Code binary if not on PATH.
ADVISOR_AUTH=auto
ADVISOR_MODEL=
ADVISOR_HISTORY_DAYS=2
CLAUDE_CLI_PATH=
# Token-budget guards (keep a review cheap — a few K tokens, not ~100K):
#   ADVISOR_MAX_THINKING_TOKENS : extended-thinking budget for the CLI. 0 = OFF.
#                                 A BOUNDED value (e.g. 2048) enables thinking for
#                                 better reasoning while staying cheap; only an
#                                 unbounded/huge budget runs away. Min ~1024.
#   ADVISOR_MAX_INPUT_CHARS     : hard cap on the prompt size. History detail is
#                                 auto-trimmed (2 days → 1 → summaries-only) to fit.
ADVISOR_MAX_THINKING_TOKENS=1024
ADVISOR_MAX_INPUT_CHARS=16000
# On-demand history retrieval (open-ended QUESTIONS only — the daily review is never
# affected). The model is shown a manifest of every day in data/history/; if a question
# needs days beyond the inline window it asks for them and the advisor pulls just those
# day files, then answers. Bounded so a deep question can't blow up:
#   ADVISOR_RETRIEVAL_MAX_DAYS  : most days one question may pull (default 14).
#   ADVISOR_RETRIEVAL_MAX_CHARS : ceiling on the extra data injected (~chars; def
#                                 120000 ≈ 30K tokens — one full day of slots is ~45K).
ADVISOR_RETRIEVAL_MAX_DAYS=14
ADVISOR_RETRIEVAL_MAX_CHARS=120000
# Optional: dedicated Claude Code config dir for the advisor. Set this (e.g.
# data/.claude_advisor) when using CLAUDE_CODE_OAUTH_TOKEN so the CLI authenticates
# purely from the token and isn't poisoned by a stale ~/.claude/.credentials.json
# cache (a known Claude Code 401 cause). Leave empty to use the host's normal login.
CLAUDE_CONFIG_DIR=data/.claude_advisor
# Advanced: override the Claude Code streaming flags if your installed CLI differs.
# ADVISOR_CLI_STREAM_ARGS=--output-format stream-json --verbose --include-partial-messages
# In a CONTAINER there is no interactive `claude` login — set CLAUDE_CODE_OAUTH_TOKEN
# in .secrets (from `claude setup-token`); ADVISOR_AUTH=auto then uses it.
#
# Provider-agnostic alternative — use a DIFFERENT subscription instead of Claude.
# ADVISOR_CLI_CMD points the advisor at any subscription-login CLI: the prompt is
# piped on stdin, stdout is streamed back as the report. No API key, usage drawn
# from that plan. Takes precedence over the Claude path (unless ADVISOR_AUTH=api).
# Use {prompt} where the CLI wants the prompt as an argument; omit it to pipe stdin.
#   Gemini (Google AI Pro / free tier, after `gemini login`):  ADVISOR_CLI_CMD=gemini -p {prompt}
#   OpenAI Codex CLI (ChatGPT Pro, after signing in):          ADVISOR_CLI_CMD=codex exec {prompt}
# Leave empty to use the Claude Code path above.
ADVISOR_CLI_CMD=
