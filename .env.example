### rename this file to .env and edit the settings to your liking

# Timezone
TIMEZONE='Europe/Amsterdam'

# Your Home consumes roughyl this amount of energy (in kWh) per 24 hours.
DAILY_HOME_ENERGY_CONSUMPTION=16.0

# Module/Feature toggles
# You can select one or more modules to run but make sure that `mqtt_client` is always enabled and is always the
# module defined. This is because the `mqtt_client` module is the one that is responsible for the MQTT connection
# and is a blocking function which will not return while the other modules run in their own threads.
ACTIVE_MODULES='[{"sync": {"ev_charge_controller": false, "energy_broker": false }, "async": {"mqtt_client": true, "tibber_api": false }}]'

# Enable / disable appliance run scheduling at lowest prices (requires a homeconnect2mqtt bridge in local network)
HOME_CONNECT_APPLIANCE_SCHEDULING=False

# Enable / disable dynamic buy and sell decisions
ESS_NET_METERING_ENABLED=False
# Rate in Watts to export energy to the grid from the ESS
ESS_EXPORT_AC_SETPOINT=-10000.0

# Percentage of battery capacity to retain for own use (ie. stop energy sale at 65% battery state of charge)
ESS_NET_METERING_BATT_MIN_SOC=50.0

VICTRON_OPTIMIZED_CHARGING=1
TIBBER_UPDATES_ENABLED=0

# the max amount you want to pay in cents per kWh from Tibber (energy supplier) when charging the ESS
MAX_TIBBER_BUY_PRICE=0.40

# Nightly scheduled charging guardrails
# When enabled, the 21:30 nightly scheduler will skip scheduling new charge slots
# if the battery SoC is already within the configured high range.
NIGHT_CHARGE_SKIP_ENABLED=1
NIGHT_CHARGE_SKIP_MIN_SOC=70
NIGHT_CHARGE_SKIP_MAX_SOC=100

# !!! Warning !!!
# Unless mitigated in some other way, if the grid is lost when using this mode, the loads will also
# lose power until grid power is restored or manual intervention is done (switch back to inverter mode on).
# Use this carefully.
#
# If energy prices are equal or lower to this, switch to grid consumption (victron inverter pass-through mode)
SWITCH_TO_GRID_PRICE_THRESHOLD=0.22

### ev_charge_controller ESS options
# LOAD_RESERVATION defines the amount of solar energy produced in Watts that you want to reserve for charging your ESS
# and running house (and other) loads. When the MINIMUM_ESS_SOC percentage is reached, this amount will be reduced with
# a division of the LOAD_RESERVATION by the LOAD_REDUCTION_FACTOR to begin favoring the charge of your electric vehicle.
LOAD_RESERVATION=1
LOAD_REDUCTION_FACTOR=1

# battery will charge at this voltage when under MIMIMUM_ESS_SOC
BATTERY_ABSORPTION_VOLTAGE=57.0
# battery charge voltage will be reduced to this voltage WHEN MIMIMUM_ESS_SOC is reached
BATTERY_FLOAT_VOLTAGE=57.0
MINIMUM_ESS_SOC=90
# batter max voltage will drop to this when MAXIMUM_ESS_SOC is reached
BATTERY_FULL_VOLTAGE=55.8
MAXIMUM_ESS_SOC=95

### ABB B2x  kWh Meter integration
# if you have integrated an ABB B23/B24 RS-485 meter into your venusOS system you can toggle this option on
# and configure the topic it will read/write to in conf.py.  This will allow for bypassing the load reservation
# functionality and result in more precise and accurate surplus power calculations
ABB_METER_INTEGRATION=0

### AI Powered ESS Algorithm
# Enable the AI powered ESS algorithm which optimizes charging and discharging based on 15-minute price data.
AI_POWERED_ESS_ALGORITHM=False
# Total capacity of the home battery in kWh
BATTERY_CAPACITY_KWH=45.0
# Efficiency of charging from AC to DC (0.90 = 90%)
AC_DC_CHARGE_EFFICIENCY=0.90
# Efficiency of discharging from DC to AC (0.90 = 90%)
AC_DC_DISCHARGE_EFFICIENCY=0.90

# Minimum battery SoC reserve (%) the optimizer always keeps, by season.
# Winter keeps a larger reserve for grid-outage resilience; summer can run lower.
MIN_SOC_RESERVE_WINTER=20.0
MIN_SOC_RESERVE_SUMMER=5.0

# DP state-of-charge discretization step (percentage points). Smaller = finer
# control but more compute (number of states ~= 100/step; keep it a divisor of
# 100 such as 10, 5, 4, 2). 5.0 is a good balance for Pi-class hardware.
OPTIMIZER_SOC_STEP_PCT=5.0

# --- PV forecast shape + intraday self-correction ---------------------------
# The per-slot PV forecast is a daily magnitude distributed by a learned daylight
# SHAPE. VRM anchors the magnitude to a fixed daily total, so on a better-than-
# forecast day "remaining" collapses while panels still produce. These let the
# magnitude self-correct from today's realised production.
#   ESS_PV_SHAPE_DAYS          : trailing days of history for the daylight shape.
#   ESS_PV_INTRADAY_CORRECTION : damping 0..1 for the upward correction (0 = off).
#   ESS_PV_INTRADAY_MAX_RATIO  : cap on projected day total vs VRM (anti-runaway).
#   ESS_PV_INTRADAY_MIN_ELAPSED: min fraction of the day's solar elapsed before
#                                extrapolating.
ESS_PV_SHAPE_DAYS=3
ESS_PV_INTRADAY_CORRECTION=0.6
ESS_PV_INTRADAY_MAX_RATIO=1.6
ESS_PV_INTRADAY_MIN_ELAPSED=0.10

# Grid/battery power limits (kW) used by the optimizer's feasibility checks.
ESS_MAX_GRID_IMPORT_KW=10.0
ESS_MAX_GRID_EXPORT_KW=10.0
# Optional: cap battery charge/discharge power separately (defaults to the grid limits).
ESS_MAX_CHARGE_KW=10.0
ESS_MAX_DISCHARGE_KW=10.0

# Report charging as full-power-to-target (how the Victron BatteryLife schedule
# actually executes) so BUY settlement predictions/economics match reality. Does
# not change control. 1 = on (default), 0 = report the raw DP trajectory.
ESS_MODEL_CHARGE_RATE=1

# Export economics. The optimizer values grid imports at the Tibber buy price
# (incl. fees/taxes) and exports at: buy_price * ESS_EXPORT_PRICE_FACTOR - ESS_EXPORT_FEE.
# Defaults (1.0 / 0.0) treat buy and sell prices symmetrically. Lower the factor
# and/or raise the fee to reflect that Tibber pays only the spot component for exports.
ESS_EXPORT_PRICE_FACTOR=1.0
ESS_EXPORT_FEE=0.0

# Value assigned to energy left in the battery at the end of the planning horizon,
# expressed as a multiple of the horizon's mean buy price. 1.0 keeps the optimizer
# from dumping the battery to the grid at the end of the window so charge can be
# carried into the next (more expensive) day. 0.0 disables terminal valuation.
ESS_TERMINAL_VALUE_FACTOR=1.0

# Expected peak buy price (currency/kWh). When > 0, end-of-horizon stored energy
# is valued at the higher of the horizon mean and this expected peak, so the
# optimizer holds charge for the typical morning/evening peaks (maximising monthly
# revenue) instead of selling into a low intra-day "high". 0 disables.
ESS_EXPECTED_PEAK_PRICE=0.0

# Hard floor (currency/kWh) below which the battery is NEVER actively discharged
# to the grid. PV-surplus feed-in is still allowed. Prevents selling stored energy
# cheaply when a real peak is likely later. 0 disables the floor.
ESS_MIN_SELL_PRICE=0.0

# Battery wear cost charged per kWh discharged from the battery (currency/kWh).
# Stops the optimizer from cycling the battery for marginal arbitrage that
# round-trip losses would eat anyway. Set to your estimated LFP cycle cost
# (e.g. ~0.03-0.06). 0 disables (no wear penalty).
ESS_BATTERY_CYCLE_COST=0.0

# (#1) Arbitrage hurdle (currency/kWh discharged), ON TOP of the wear cost above.
# A required profit cushion so thin-spread cycles (which barely clear round-trip
# losses and are most exposed to forecast error) are pruned, while fat-spread
# cycles (e.g. cheap midday charge -> evening peak sell) still clear. Start small
# (e.g. 0.02-0.04) and tune. 0 disables.
ESS_ARBITRAGE_MARGIN=0.0

# (#3) Grid-charge price ceilings — only charge the battery FROM THE GRID when
# energy is genuinely cheap, so expensive grid energy isn't stored for a thin
# resale margin. PV charging is never gated, and topping up to the seasonal
# reserve is always allowed. Both limits apply together when enabled:
#   ESS_MAX_GRID_CHARGE_PRICE : absolute ceiling (currency/kWh). E.g. 0.18 blocks
#                               grid-charging whenever the buy price exceeds 0.18.
#                               0 disables.
#   ESS_GRID_CHARGE_CHEAP_PCT : relative ceiling — only grid-charge when the buy
#                               price is in the cheapest N% of the planning
#                               horizon (adapts per-day, no retuning). E.g. 35.
#                               0 or >=100 disables.
ESS_MAX_GRID_CHARGE_PRICE=0.0
ESS_GRID_CHARGE_CHEAP_PCT=0.0

# Cost-basis sell floor (automatic): the optimizer tracks the weighted price PAID
# for the energy now in the battery (grid charge raises it, PV charge dilutes it to
# ~0) and won't actively discharge to the grid below that price + losses, so it can
# never sell stored energy for less than it cost. Persisted across restarts here;
# self-disables on an empty / PV-filled battery.
ESS_COST_BASIS_PATH=data/ess_cost_basis.json

# SELL hysteresis (anti-flap): only ever suppress *entering* a sell (never forces a
# discharge). After a sell stops, don't re-enter for this many minutes unless the
# price has risen by at least ESS_SELL_HYSTERESIS_EUR since. Stops micro-cycling a
# near-empty battery on a flat price curve. Dwell 0 disables.
ESS_SELL_MIN_DWELL_MIN=20
ESS_SELL_HYSTERESIS_EUR=0.03

# Planning resolution in minutes. With hourly Tibber prices the engine sub-divides
# each hour into slots of this size (15 = future-ready for quarter-hourly prices;
# prices are flat within the hour until Tibber publishes 15-min data). When the
# price feed is already finer than this, the native resolution is used.
OPTIMIZER_SLOT_MINUTES=15

# Tibber price resolution requested from the API. QUARTER_HOURLY pulls true
# 15-minute prices (how Tibber bills as of Oct 2025) via a direct GraphQL query;
# HOURLY requests hourly prices. On transient API failures, the service retries
# and uses the last cached quarter-hourly horizon before degrading to hourly.
TIBBER_PRICE_RESOLUTION=QUARTER_HOURLY
# Optional base path for cached price horizons. The resolution is appended to the
# filename, e.g. /dev/shm/cerbo_tibber_price_cache_QUARTER_HOURLY.json.
TIBBER_PRICE_CACHE_PATH=/dev/shm/cerbo_tibber_price_cache.json

# Optional: house-load shape used to forecast self-consumption per slot. 24
# comma-separated relative weights (00:00..23:00); leave unset to use the
# built-in residential profile (low overnight, morning + evening peaks). The
# daily total is taken from the VRM consumption forecast (or measured-so-far,
# or DAILY_HOME_ENERGY_CONSUMPTION) and distributed using this shape.
# LOAD_PROFILE_HOURLY=0.6,0.5,0.5,0.5,0.5,0.7,1.1,1.4,1.3,1.0,0.9,0.9,1.0,1.0,0.9,0.9,1.1,1.6,1.8,1.8,1.6,1.4,1.0,0.7

# When enabled, the optimizer toggles the Victron "Limit system feed-in" setting
# (MaxFeedInPower) to 0W while the current price is negative, and auto-reverts to
# unlimited (-1) once the price is non-negative again.
NEGATIVE_PRICE_FEED_IN_LIMIT_ENABLED=True

### Historical data logging
# One analytics-ready NDJSON record per optimizer cycle is appended to a per-day
# file (ess-YYYY-MM-DD.ndjson) under this directory, for later performance analysis.
HISTORY_DIR=data/history

### Frontend dashboard (frontend/)
# When True, the main service runs the read-only dashboard in-process as a daemon
# thread (guarded — it can never crash the controller). False = run it standalone
# (python -m frontend) or as a container sidecar.
FRONTEND_ENABLED=False
# The main service publishes the current plan as JSON to this path; the dashboard
# reads it. Shared in-memory location works for a same-host sidecar.
AI_PLAN_EXPORT_PATH=/dev/shm/cerbo_ai_plan.json
# Bind address/port for the read-only dashboard (run: python -m frontend).
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=8080
# When True, log every dashboard HTTP request (werkzeug). Default False keeps the
# (especially in-process) service log clean; errors are still logged.
FRONTEND_DEBUG=False
# Domoticz device IDXs read once a minute for the dashboard (EV charging power in
# Watts, and gas usage in m³). Best-effort; absent/unreadable => node hidden.
DOMOTICZ_EV_IDX=627
DOMOTICZ_GAS_IDX=29

# --- AI Advisor (read-only dashboard review tab) ---------------------------
# Credentials in .secrets: CLAUDE_CODE_OAUTH_TOKEN (preferred — uses your Claude
# Pro/Max subscription via `claude setup-token`, no API key) or ANTHROPIC_API_KEY
# (pay-as-you-go fallback). Only allow-listed tunables + history are sent; never
# secrets. The advisor is read-only and cannot change config or control.
ADVISOR_AUTH=auto
ADVISOR_MODEL=
ADVISOR_HISTORY_DAYS=2
CLAUDE_CLI_PATH=
# Token-budget guards: keep each review cheap. Extended thinking was the runaway
# cost, so it's OFF by default (0). The prompt is also hard-capped; history detail
# auto-trims to fit.
ADVISOR_MAX_THINKING_TOKENS=0
ADVISOR_MAX_INPUT_CHARS=16000
# On-demand history retrieval for open-ended QUESTIONS (not the daily review). The
# model sees a manifest of every day in data/history/ and can pull specific days it
# needs to answer, bounded by these:
ADVISOR_RETRIEVAL_MAX_DAYS=14
ADVISOR_RETRIEVAL_MAX_CHARS=120000
# Provider-agnostic CLI (optional). Point the advisor at ANY subscription-login
# CLI instead of Claude Code — no API key, usage drawn from that plan. The prompt
# is piped on stdin and stdout is streamed back as the report. Takes precedence
# over the Claude path (unless ADVISOR_AUTH=api). Examples:
# Use {prompt} where the CLI wants the prompt as an argument; omit it to pipe stdin.
#   ADVISOR_CLI_CMD=gemini -p {prompt}    # Gemini CLI, after `gemini login` (free tier)
#   ADVISOR_CLI_CMD=codex exec {prompt}   # OpenAI Codex CLI, after signing in with ChatGPT
ADVISOR_CLI_CMD=
